# 飞书应用凭证
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret

# 飞书多维表格配置
FEISHU_BASE_APP_TOKEN=D6JAbvNKZaUgMGsTfkPcgXn2nBd
FEISHU_TABLE_ID=tbluFzEQv1KRMsiG

# ===== 浏览器模式 =====
# profile — 复制本机 Chrome 登录态（推荐，无需重新登录）
# login   — 打开浏览器让用户手动登录
# cdp     — 连接已开启 --remote-debugging-port 的 Chrome
BROWSER_MODE=profile

# profile 模式: Chrome 用户数据目录（留空则自动检测）
# Windows:  C:\Users\<用户名>\AppData\Local\Google\Chrome\User Data
# macOS:    ~/Library/Application Support/Google/Chrome
CHROME_USER_DATA_DIR=

# cdp 模式: Chrome 调试端口
CHROME_DEBUG_PORT=9222

# login 模式: 等待登录超时（秒）
LOGIN_TIMEOUT=300

# 监控间隔（秒）
MONITOR_INTERVAL=10

# 评论检查范围（分钟）
COMMENT_CHECK_MINUTES=5
